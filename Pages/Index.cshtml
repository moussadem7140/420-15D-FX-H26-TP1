@page
@model _420_15D_FX_H26_TP1.Pages.Evenements.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1 class="fw-bold text-white">Les Evenements</h1>
<div class="container py-3 text-center">
    <div class="row g-2 align-items-center">

        <!-- Search -->
        <div class="col-12 col-lg">
            <form class="input-group input-group-lg" method="get" asp-page="/Evenements/Index">
                <input class="form-control border-0 bg-dark text-white"
                       type="text"
                       name="q"
                       placeholder="Rechercher un événement (nom, ville, catégorie...)"
                       autocomplete="off" />
                <button class="btn btn-gradient px-4" type="submit">Rechercher</button>

            </form>
        </div>

        <!-- Quick actions -->
        <div class="col-12 col-lg-auto">
            <div class="d-flex gap-2 justify-content-lg-end">

                <a class="btn btn-dark btn-lg d-flex align-items-center gap-2 qa-btn"
                   asp-page="/Participations/MesParticipations" title="Mes participations">
                    <span class="qa-emoji">🎟️</span>
                    <span class="d-none d-md-inline">Mes participations</span>
                </a>

                <a class="btn btn-dark btn-lg d-flex align-items-center gap-2 qa-btn"
                   asp-page="/Evenements/MesOrganisations" title="Mes organisations">
                    <span class="qa-emoji">📌</span>
                    <span class="d-none d-md-inline">Mes organisations</span>
                </a>

            </div>
        </div>
    </div>
</div>

<p>
    <a asp-page="/Evenements/Create" class="btn btn-dark btn-lg d-flex align-items-center gap-2 qa-btn align-items-center m-0">Ajouter un evenement</a>
</p>

@foreach (var item in Model.Evenement) {
    @await Html.PartialAsync("_Evenement", item)
}

@{if(TempData["successMessage"] != null)
  {
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["successMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  }

}
