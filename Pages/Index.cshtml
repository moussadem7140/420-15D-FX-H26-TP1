@page
@model _420_15D_FX_H26_TP1.Pages.Evenements.IndexModel

@{
    ViewData["Title"] = "Index";
}

@{
    if (TempData["successMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-success" role="alert">
            @TempData["successMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
}
@{
    if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-danger" role="alert">
            @TempData["successMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
}
<div class="container py-3 text-center">
    <div class="row g-2 align-items-center">

        <div class="col-lg-8">
            <form method="get"
                  asp-page="/Index"
                  class="input-group input-group-lg">

                <input asp-for="motCle"
                       class="form-control border-0 bg-dark text-white"
                       placeholder="Rechercher un événement "
                       type="text" />

                <select asp-for="CategorieCle"
                        class="form-select border-0" asp-items="@Model.Categories">
                    <option value="">-- Toutes les catégories --</option>
                </select>

                <button type="submit" class="btn btn-success px-4">
                    Rechercher
                </button>
            </form>
        </div>

        @if (User.Identity.IsAuthenticated)
        {
            <div class="col-lg-4">
                <div class="d-flex justify-content-lg-end gap-2">

                    <a class="btn btn-success btn-lg d-flex align-items-center gap-2 qa-btn"
                       asp-page="/Index"
                       asp-page-handler="Participations"
                       title="Mes participations">
                        <span class="qa-emoji">🎟️</span>
                        <span class="d-none d-md-inline">Participations</span>
                    </a>

                    <a class="btn btn-success btn-lg d-flex align-items-center gap-2 qa-btn"
                       asp-page="/Index"
                       asp-page-handler="MesEvenements"
                       title="Mes organisations">
                        <span class="qa-emoji">📌</span>
                        <span class="d-none d-md-inline">Organisations</span>
                    </a>

                </div>
            </div>
        }
    </div>
</div>
       
@{
    if (User.Identity.IsAuthenticated)
    {
        <p class="container text-center">
            <a asp-page="/Evenements/Create" class="qa-btn p-5 pt-2 pb-2 text-white fw-bold text-center text-decoration-none">Ajouter un evenement</a>
        </p>            
    }
}

<div  class="row justify-content-around gap-2">
    @foreach (var item in @Model.Evenements)
    {
        <div class="col-3">
            @await Html.PartialAsync("_Evenement", item)
        </div>
    }

</div>




