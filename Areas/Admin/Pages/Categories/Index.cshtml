@page
@model _420_15D_FX_H26_TP1.Areas.Admin.Pages.Categories.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="/Categories/Create" asp-area="Admin">Créer une Categorie</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Categorie[0].Nom)
            </th>
           
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Categorie) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nom)
            </td>

            <td>
                <a asp-page="/Categories/Edit" asp-aria="Admin" asp-route-id="@item.Id" class="btn btn-primary">Edit</a> |
                    <a asp-page="/Categories/Details" asp-aria="Admin" asp-route-id="@item.Id" class="btn btn-primary">Details</a> |
                    <a asp-page="/Categories/Delete" asp-aria="Admin" asp-route-id="@item.Id" class="btn btn-primary">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
@{if(TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

}